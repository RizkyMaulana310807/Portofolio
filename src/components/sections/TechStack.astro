---
import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";
import { techCategories } from "@/data/skills";
// Kelompokkan sesuai kebutuhan kamu.
// Silakan tambah/kurangi/pindah item antar kategori.
---

<Section
  class="bg-white py-20 transition-colors duration-300 sm:py-28 dark:bg-neutral-950"
>
  <Container>
    <!-- Eyebrow + heading -->
    <div class="mx-auto max-w-2xl text-center">
      <p
        class="text-sm font-semibold uppercase tracking-widest text-blue-600 dark:text-blue-400"
      >
        Tech Stack
      </p>
      <h2
        class="mt-3 text-3xl font-extrabold tracking-tight text-neutral-900 sm:text-4xl dark:text-white"
      >
        Tools I Work With
      </h2>
      <p class="mt-4 text-base text-neutral-600 dark:text-neutral-400">
        A mix of web technologies and game engines I use to build
        reliable, interactive products.
      </p>
    </div>

    <!-- Grid kategori -->
    <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        techCategories.map((category) => (
          <div
            class="rounded-2xl border border-neutral-200 bg-neutral-50 p-6 transition-colors duration-300 dark:border-neutral-800 dark:bg-neutral-900"
          >
            <h3 class="text-sm font-semibold text-neutral-900 dark:text-white">
              {category.label}
            </h3>

            <ul class="mt-4 flex flex-col gap-2">
              {category.items.map((item) => (
                <li
                  class="flex items-center gap-2.5 text-sm text-neutral-600 dark:text-neutral-400"
                >
                  <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-blue-600 dark:bg-blue-400" />
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </Container>
</Section>