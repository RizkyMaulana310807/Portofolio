---
import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";
import { Projects } from "@/data/projects";
---

<Section class="bg-neutral-50 transition-colors duration-300 dark:bg-neutral-900 py-20 sm:py-28 border-t border-neutral-100 dark:border-neutral-800/50">
  <Container id="projects">
    
    <!-- Section Header -->
    <div class="max-w-3xl mx-auto text-center mb-16 sm:mb-20">
      <Badge class="mb-4 sm:mb-5">
        ⚡ Problem Solving Case Studies
      </Badge>
      <h2 class="text-3xl font-extrabold tracking-tight text-neutral-900 sm:text-4xl lg:text-5xl dark:text-white">
        Behind the Code: <span class="text-blue-600 dark:text-blue-400">Featured Projects</span>
      </h2>
      <p class="mt-4 text-base leading-relaxed text-neutral-600 sm:text-lg dark:text-neutral-400">
        Bukan sekadar memajang antarmuka. Ini adalah bagaimana saya menganalisis tantangan teknis, mengoptimalkan arsitektur, dan merumuskan solusi efisien.
      </p>
    </div>

    <!-- Grid Layout (Dibatasi hanya 3 data teratas) -->
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
      {
        Projects.slice(0, 3).map((project) => (
          <div class="flex flex-col justify-between bg-white dark:bg-neutral-950 border border-neutral-200 dark:border-neutral-800/60 rounded-2xl p-6 sm:p-8 shadow-sm transition-all duration-300 hover:shadow-md hover:border-neutral-300 dark:hover:border-neutral-700">
            
            <div>
              <!-- Project Title -->
              <h3 class="text-xl font-bold tracking-tight text-neutral-900 dark:text-white mb-5 line-clamp-2 min-h-[3.5rem]">
                {project.title}
              </h3>
              
              <!-- Problem Box -->
              <div class="mb-5 bg-rose-50/50 dark:bg-rose-950/20 border border-rose-100 dark:border-rose-900/30 rounded-xl p-4">
                <span class="text-xs font-bold uppercase tracking-wider text-rose-600 dark:text-rose-400 block mb-1">
                  🔴 The Challenge
                </span>
                <p class="text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed">
                  {project.problem}
                </p>
              </div>

              <!-- Solution Box -->
              <div class="mb-6 bg-emerald-50/50 dark:bg-emerald-950/20 border border-emerald-100 dark:border-emerald-900/30 rounded-xl p-4">
                <span class="text-xs font-bold uppercase tracking-wider text-emerald-600 dark:text-emerald-400 block mb-1">
                  🟢 The Solution
                </span>
                <p class="text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed">
                  {project.solution}
                </p>
              </div>
            </div>

            <!-- Tech Stack Footer -->
            <div class="pt-5 border-t border-neutral-100 dark:border-neutral-900">
              <div class="flex flex-wrap gap-1.5">
                {
                  project.techStack.map((tech) => (
                    <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold bg-neutral-100 text-neutral-800 dark:bg-neutral-800 dark:text-neutral-300 transition-colors">
                      {tech}
                    </span>
                  ))
                }
              </div>
            </div>

          </div>
        ))
      }
    </div>

    <!-- Call to action mengarah ke halaman internal baru -->
    <div class="mt-16 text-center">
      <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-4">
        Ingin melihat detail arsitektur dan daftar proyek saya selengkapnya?
      </p>
      <Button href="/projects" class="inline-flex items-center gap-2">
        Lihat Semua Project →
      </Button>
    </div>

  </Container>
</Section>