---
import Container from "@/components/ui/Container.astro";
import Section from "@/components/ui/Section.astro";
import Badge from "@/components/ui/Badge.astro";
import Image from "astro/components/Image.astro";
import profileImage from '../../assets/images/profile.webp';
import { profile } from "@/data/profile";
// Fallback aman kalau field belum ada di data/profile.ts
const bio =
  profile.bio ??
  "I'm a developer who enjoys turning ideas into fast, reliable products — from interactive games to full-stack web applications. I care about clean code, thoughtful UX, and shipping things that actually work.";

const location = profile.location ?? "Indonesia";
const yearsExperience = profile.yearsExperience ?? 2;
const projectsCount = profile.projectsCount ?? 10;
const availability = profile.availability ?? "Open to Work";

const stack: string[] = profile.stack ?? [
  "JavaScript",
  "TypeScript",
  "React",
  "Astro",
  "Phaser.js",
  "Three.js",
  "Unity",
  "Godot",
];

const quickFacts = [
  { label: "Location", value: location },
  { label: "Experience", value: `${yearsExperience}+ years` },
  { label: "Status", value: availability },
];
---

<Section class="bg-neutral-50 py-20 transition-colors duration-300 sm:py-28 dark:bg-neutral-900/40">
  <Container id="about">
    <!-- Eyebrow + heading -->
    <div class="mx-auto max-w-2xl text-center">
      <p
        class="text-sm font-semibold uppercase tracking-widest text-blue-600 dark:text-blue-400"
      >
        About Me
      </p>
      <h2
        class="mt-3 text-3xl font-extrabold tracking-tight text-neutral-900 sm:text-4xl dark:text-white"
      >
        Who I Am
      </h2>
    </div>

    <div
      class="mt-14 grid items-start gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.3fr)] lg:gap-16"
    >
      <!-- Left: photo + quick facts -->
      <div class="mx-auto w-full max-w-sm lg:mx-0">
        <div
          class="flex aspect-square w-full items-center justify-center rounded-2xl bg-neutral-200 text-neutral-500 shadow-lg dark:bg-neutral-800 dark:text-neutral-400 dark:shadow-neutral-950/40"
        >
            <Image 
                src={profileImage} 
                alt="Foto Profil" 
                class="w-full h-full object-cover"
                width={320}
                height={320}
                loading="eager" 
                fetchpriority="high"
            />
        </div>

        <dl
          class="mt-6 divide-y divide-neutral-200 rounded-2xl border border-neutral-200 bg-white dark:divide-neutral-800 dark:border-neutral-800 dark:bg-neutral-900"
        >
          {
            quickFacts.map((fact) => (
              <div class="flex items-center justify-between px-5 py-3.5">
                <dt class="text-sm text-neutral-500 dark:text-neutral-400">
                  {fact.label}
                </dt>
                <dd class="text-sm font-semibold text-neutral-900 dark:text-white">
                  {fact.value}
                </dd>
              </div>
            ))
          }
        </dl>
      </div>

      <!-- Right: bio + stats + stack -->
      <div>
        <p
          class="text-lg leading-8 text-neutral-600 dark:text-neutral-400"
        >
          {bio}
        </p>

        <!-- Stats -->
        <div
          class="mt-8 grid grid-cols-2 gap-6 border-y border-neutral-200 py-6 sm:grid-cols-2 dark:border-neutral-800"
        >
          <div>
            <p
              class="text-3xl font-extrabold tabular-nums text-neutral-900 sm:text-4xl dark:text-white"
            >
              {yearsExperience}+
            </p>
            <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
              Years of Experience
            </p>
          </div>
          <div>
            <p
              class="text-3xl font-extrabold tabular-nums text-neutral-900 sm:text-4xl dark:text-white"
            >
              {projectsCount}+
            </p>
            <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
              Projects Completed
            </p>
          </div>
        </div>

        <!-- Tech stack -->
        <div class="mt-8">
          <p
            class="text-sm font-semibold text-neutral-900 dark:text-white"
          >
            Core Stack
          </p>
          <div class="mt-3 flex flex-wrap gap-2">
            {
              stack.map((tech) => (
                <Badge class="bg-white text-neutral-700 shadow-sm ring-1 ring-neutral-200 dark:bg-neutral-900 dark:text-neutral-300 dark:ring-neutral-800">
                  {tech}
                </Badge>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </Container>
</Section>