---
import { navigation } from "../../data/navigation";
import ThemeToggle from "./ThemeToggle.astro";
---

<header
  class="sticky top-0 z-50 border-b border-neutral-200 bg-white/80 backdrop-blur transition-colors duration-300 dark:border-neutral-800 dark:bg-neutral-950/80"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6">

    <a href={`${import.meta.env.BASE_URL}`} class="text-lg font-bold text-neutral-900 dark:text-white">
      Portfolio
    </a>

    <!-- Menu desktop -->
    <ul class="hidden items-center gap-8 md:flex">
      {
        navigation.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm font-medium text-neutral-600 transition hover:text-black dark:text-neutral-400 dark:hover:text-white"
            >
              {item.title}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2">
      <ThemeToggle />

      <!-- Tombol hamburger, hanya tampil di mobile/tablet -->
      <button
        id="menu-toggle"
        type="button"
        aria-label="Toggle menu"
        aria-expanded="false"
        class="relative inline-flex h-9 w-9 items-center justify-center rounded-full text-neutral-600 transition hover:bg-neutral-100 md:hidden dark:text-neutral-300 dark:hover:bg-neutral-800"
      >
        <svg
          id="icon-open"
          class="h-6 w-6 transition-all duration-300"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
        </svg>
        <svg
          id="icon-close"
          class="absolute h-6 w-6 scale-0 opacity-0 transition-all duration-300"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

  </nav>

  <!--
    Menu mobile (dropdown) — animasi pakai grid-template-rows trick:
    0fr -> 1fr untuk height, dibarengi fade opacity.
    Ini cara paling mulus buat animasi height "auto" di CSS murni.
  -->
  <div
    id="mobile-menu"
    class="grid grid-rows-[0fr] overflow-hidden opacity-0 transition-[grid-template-rows,opacity] duration-300 ease-in-out md:hidden"
  >
    <div class="min-h-0 overflow-hidden border-t border-neutral-200 dark:border-neutral-800">
      <ul class="flex flex-col gap-1 px-4 py-4 sm:px-6">
        {
          navigation.map((item) => (
            <li>
              <a
                href={item.href}
                class="block rounded-lg px-3 py-2 text-sm font-medium text-neutral-600 transition hover:bg-neutral-100 hover:text-black dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-white"
              >
                {item.title}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</header>

<script is:inline>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  let isOpen = false;

  menuToggle?.addEventListener("click", () => {
    isOpen = !isOpen;

    // Animasi grid-rows: 0fr (tertutup) <-> 1fr (terbuka)
    mobileMenu?.classList.toggle("grid-rows-[0fr]", !isOpen);
    mobileMenu?.classList.toggle("grid-rows-[1fr]", isOpen);
    mobileMenu?.classList.toggle("opacity-0", !isOpen);
    mobileMenu?.classList.toggle("opacity-100", isOpen);

    // Animasi ikon: rotate + fade + scale
    iconOpen?.classList.toggle("rotate-90", isOpen);
    iconOpen?.classList.toggle("scale-0", isOpen);
    iconOpen?.classList.toggle("opacity-0", isOpen);

    iconClose?.classList.toggle("scale-0", !isOpen);
    iconClose?.classList.toggle("opacity-0", !isOpen);
    iconClose?.classList.toggle("rotate-0", !isOpen);
    iconClose?.classList.toggle("-rotate-90", isOpen);

    menuToggle?.setAttribute("aria-expanded", String(isOpen));
  });
</script>