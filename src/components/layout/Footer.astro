---
import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";
import Button from "../ui/Button.astro";
import Badge from "../ui/Badge.astro";

import { Icon } from "astro-icon/components";
import { profile } from "../../data/profile";
import { socials } from "@/data/socials";

const currentYear = new Date().getFullYear();
---

<Section class="bg-white transition-colors duration-300 dark:bg-neutral-950 py-20 sm:py-28 border-t border-neutral-100 dark:border-neutral-800/40">
  <Container id="footer">
    
    <!-- Contact Card Call-to-Action -->
    <div class="max-w-4xl mx-auto bg-neutral-50 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-3xl p-6 sm:p-12 text-center shadow-sm">
      <Badge class="mb-4">
        📫 Get In Touch
      </Badge>
      
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold tracking-tight text-neutral-900 dark:text-white">
        Let's Build Something <span class="text-blue-600 dark:text-blue-400">Great Together</span>
      </h2>
      
      <p class="mt-4 mx-auto max-w-xl text-sm sm:text-base leading-relaxed text-neutral-600 dark:text-neutral-400">
        Saya selalu terbuka untuk diskusi mengenai arsitektur backend, otomasi sistem, integrasi AI lokal, atau peluang kerja full-stack.
      </p>

      <!-- Action Buttons (Dipecah jadi 2 versi CV) -->
      <div class="mt-8 flex flex-wrap justify-center gap-3 sm:gap-4">
        
        <!-- Tombol Kirim Email -->
        <Button href={`mailto:${profile.email || 'emailmu@domain.com'}`}>
          ✉️ Send an Email
        </Button>
        
            <!-- Tombol CV Bahasa Indonesia -->
            <Button 
            href={`${import.meta.env.BASE_URL}pdfs/FULLSTACK_DEVELOPER_RIZKY_MAULANA_ID.pdf`} 
            variant="secondary" 
            class="hover"
            download="CV_Rizky_Maulana_ID.pdf"
            >
            🇮🇩 Download CV (ID)
            </Button>

            <!-- Tombol CV Bahasa Inggris -->
            <Button 
            href={`${import.meta.env.BASE_URL}pdfs/FULLSTACK_DEVELOPER_RIZKY_MAULANA_EN.pdf`} 
            variant="secondary" 
            class="hover"
            download="CV_Rizky_Maulana_EN.pdf"
            >
            🇬🇧 Download CV (EN)
            </Button>
        </div>

      <!-- Social Links Row (Responsive Fix) -->
      <div class="mt-10 flex flex-wrap justify-center items-center gap-3 sm:gap-6 border-t border-neutral-200 dark:border-neutral-800 pt-8">
        {
          socials.map((social) => (
            <a 
              href={social.url} 
              target="_blank" 
              rel="noopener noreferrer" 
              aria-label={social.name}
              class="group flex items-center justify-center sm:justify-start gap-2 p-2.5 sm:p-0 rounded-xl sm:rounded-none bg-neutral-100 dark:bg-neutral-800/60 sm:bg-transparent sm:dark:bg-transparent border border-neutral-200/80 dark:border-neutral-700/60 sm:border-0 text-sm font-medium text-neutral-600 dark:text-neutral-400 hover:text-blue-600 dark:hover:text-blue-400 transition-all duration-300"
            >
              <Icon 
                name={social.icon} 
                class="w-5 h-5 transition-transform duration-300 group-hover:-translate-y-1 group-hover:scale-110 shrink-0" 
              />
              <span class="hidden sm:inline">{social.name}</span>
            </a>
          ))
        }
      </div>
    </div>

    <!-- Tiny Copyright Footer -->
    <div class="mt-16 text-center">
      <p class="text-xs text-neutral-400 dark:text-neutral-600">
        &copy; {currentYear} {profile.name || 'Your Name'}. Built with Astro & Tailwind CSS. All rights reserved.
      </p>
    </div>

  </Container>
</Section>