---
import MainLayout from "../layouts/MainLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import profileImage from "../assets/images/profile.webp";
import { profile } from "../data/profile";
import { socials } from "../data/socials";

const base = import.meta.env.BASE_URL;

const primaryLinks = [
  {
    name: "Website Portofolio",
    url: base, // Mengarah ke base path (misal: /Portofolio/)
    icon: "mdi:web",
    isHighlight: true,
  },
  {
    name: "Download CV (Indonesia)",
    url: `${base}/pdfs/FULLSTACK_DEVELOPER_RIZKY_MAULANA_ID.pdf`,
    icon: "mdi:file-document-outline",
    isHighlight: false,
    download: "CV_Rizky_Maulana_ID.pdf",
  },
  {
    name: "Download CV (English)",
    url: `${base}/pdfs/FULLSTACK_DEVELOPER_RIZKY_MAULANA_EN.pdf`,
    icon: "mdi:file-document-outline",
    isHighlight: false,
    download: "CV_Rizky_Maulana_EN.pdf",
  },
];
---

<MainLayout title={`Links | ${profile.name || "Developer"}`} description="Semua tautan penting dan sosial media resmi.">
  <Section class="flex items-center bg-white transition-colors duration-300 dark:bg-neutral-950 py-16 sm:py-24">
    <Container>
      <main class="w-full max-w-md mx-auto flex flex-col items-center">
        
        <!-- Profile Header -->
        <div class="mb-10 text-center w-full">
          <div class="flex aspect-square w-28 h-28 mx-auto items-center justify-center rounded-full bg-neutral-200 text-neutral-500 shadow-xl dark:bg-neutral-800 dark:text-neutral-400 overflow-hidden border-4 border-white dark:border-neutral-900 mb-5">
            <Image 
              src={profileImage} 
              alt={profile.name || "Foto Profil"} 
              class="w-full h-full object-cover"
              width={112}
              height={112}
              loading="eager" 
              fetchpriority="high"
            />
          </div>

          <h1 class="text-2xl font-extrabold tracking-tight text-neutral-900 dark:text-white mb-1">
            {profile.name || "Your Name"}
          </h1>
          
          <p class="text-sm font-medium text-blue-600 dark:text-blue-400 mb-3">
            {profile.role || "Backend / Full-Stack Web Developer"}
          </p>
          
          <p class="text-sm text-neutral-600 dark:text-neutral-400 px-4 leading-relaxed">
            Mari terhubung dan diskusikan peluang kolaborasi, arsitektur sistem, atau sekadar berbagi wawasan teknologi.
          </p>
        </div>

        <!-- Links Container -->
        <div class="w-full flex flex-col gap-4">
          
          <!-- Primary Links (Portofolio & Kedua Versi CV) -->
          {
            primaryLinks.map((link) => (
              <a 
                href={link.url}
                download={link.download}
                class={`group flex items-center justify-between w-full p-4 sm:p-5 rounded-2xl transition-all duration-300 shadow-sm hover:shadow-md hover:-translate-y-1 ${
                  link.isHighlight 
                    ? 'bg-blue-600 text-white border border-blue-600 hover:bg-blue-700 hover:border-blue-700' 
                    : 'bg-neutral-50 dark:bg-neutral-900/60 border border-neutral-200/60 dark:border-neutral-800/60 hover:border-blue-300 dark:hover:border-blue-800 text-neutral-900 dark:text-white'
                }`}
              >
                <div class="flex items-center gap-4">
                  <Icon name={link.icon} class={`w-6 h-6 ${link.isHighlight ? 'text-white' : 'text-blue-600 dark:text-blue-400'}`} />
                  <span class="font-bold text-sm sm:text-base tracking-wide">{link.name}</span>
                </div>
                <Icon name={link.download ? "mdi:download" : "mdi:chevron-right"} class={`w-5 h-5 transition-transform duration-300 group-hover:translate-x-1 ${link.isHighlight ? 'text-blue-200' : 'text-neutral-400'}`} />
              </a>
            ))
          }

          <!-- Divider -->
          <div class="w-full flex items-center gap-4 my-4 opacity-60">
            <div class="flex-1 h-px bg-neutral-300 dark:bg-neutral-800"></div>
            <span class="text-xs font-semibold text-neutral-500 uppercase tracking-widest text-neutral-500">Connect</span>
            <div class="flex-1 h-px bg-neutral-300 dark:bg-neutral-800"></div>
          </div>

          <!-- Social Media Links (Otomatis dari socials.ts) -->
          {
            socials.map((social) => (
              <a 
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center justify-between w-full p-4 sm:p-5 rounded-2xl bg-neutral-50 dark:bg-neutral-900/40 border border-neutral-200/60 dark:border-neutral-800/60 hover:border-neutral-300 dark:hover:border-neutral-700 hover:bg-neutral-100/60 dark:hover:bg-neutral-900 transition-all duration-300 hover:-translate-y-1 text-neutral-900 dark:text-white"
              >
                <div class="flex items-center gap-4">
                  <Icon name={social.icon} class="w-6 h-6 text-neutral-600 dark:text-neutral-400 group-hover:text-blue-500 transition-colors" />
                  <span class="font-semibold text-sm sm:text-base">{social.name}</span>
                </div>
                <Icon name="mdi:arrow-top-right" class="w-4 h-4 text-neutral-400 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" />
              </a>
            ))
          }

        </div>

      </main>
    </Container>
  </Section>
</MainLayout>